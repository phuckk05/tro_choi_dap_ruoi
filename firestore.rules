rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{playerId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly([
          'playerId',
          'playerName',
          'bestScore',
          'playedAt',
          'updatedAt'
        ])
        && request.resource.data.playerId == playerId
        && request.resource.data.playerName is string
        && request.resource.data.playerName.size() > 0
        && request.resource.data.playerName.size() <= 30
        && request.resource.data.bestScore is int
        && request.resource.data.bestScore >= 0
        && request.resource.data.playedAt is timestamp;

      allow update: if resource.data.playerId == playerId
        && request.resource.data.keys().hasOnly([
          'playerId',
          'playerName',
          'bestScore',
          'playedAt',
          'updatedAt'
        ])
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.playerName is string
        && request.resource.data.playerName.size() > 0
        && request.resource.data.playerName.size() <= 30
        && request.resource.data.bestScore is int
        && request.resource.data.bestScore >= resource.data.bestScore
        && request.resource.data.playedAt is timestamp;

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
